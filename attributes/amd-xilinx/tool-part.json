{
  "id": "tool_part",
  "label": "Tool Part",
  "section": "Vivado",
  "order": 10,
  "description": "Lowercase device identifier used by Vivado (e.g. as the -part argument). Computed from decoder fields; rules vary per family.",
  "format": "string",
  "copyable": true,
  "compute": [
    {
      "description": "7-series: device+package-speed, lowercase, no temp grade.",
      "families": ["Spartan-7", "Artix-7", "Kintex-7", "Virtex-7", "Zynq-7000"],
      "template": "{product_grade}{family}{density}{package}-{speed}",
      "transform": "lowercase"
    },
    {
      "description": "UltraScale / UltraScale+: device-package-speed-temp, lowercase.",
      "families": ["Artix UltraScale+", "Spartan UltraScale+", "Kintex UltraScale", "Kintex UltraScale+", "Virtex UltraScale", "Virtex UltraScale+"],
      "template": "{product_grade}{family}{density}-{package}-{speed}-{temp}",
      "transform": "lowercase"
    },
    {
      "description": "Zynq UltraScale+: device+type-package-speed-temp, lowercase.",
      "families": ["Zynq UltraScale+ MPSoC", "Zynq UltraScale+ RFSoC"],
      "template": "{product_grade}{family}{density}{device_type}-{package}-{speed}-{temp}",
      "transform": "lowercase"
    },
    {
      "description": "Versal: device-package-speed_voltage_screen-temp, lowercase. Package = ball_pitch+lid+rohs+footprint.",
      "families": ["Versal AI Core", "Versal AI Edge", "Versal AI Edge Gen 2", "Versal HBM", "Versal Premium", "Versal Prime", "Versal Prime Gen 2"],
      "template": "{product_grade}{versal}{series}{device_number}-{ball_pitch}{lid}{rohs}{footprint}-{speed_grade}{voltage}{static_screen}-{temp_grade}",
      "transform": "lowercase"
    }
  ]
}
