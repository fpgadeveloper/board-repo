{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FPGA Development Boards",
  "description": "A collection of FPGA development boards with their specifications and features.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/board"
  },
  "$defs": {
    "board": {
      "type": "object",
      "required": ["id", "name", "status", "url", "vendor", "price", "device"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the board (URL-safe slug recommended)."
        },
        "name": {
          "type": "string",
          "description": "Display name of the board."
        },
        "status": {
          "type": "string",
          "enum": ["active", "eol", "discontinued"],
          "description": "Whether the board is currently available, end-of-life, or discontinued."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Product page URL."
        },
        "vendor": {
          "type": "string",
          "description": "Board vendor key (must match a key in vendors.json board_vendors)."
        },
        "price": {
          "$ref": "#/$defs/price"
        },
        "device": {
          "$ref": "#/$defs/device"
        },
        "pcie": {
          "type": "array",
          "description": "PCIe interfaces on the board. Each entry is a separate physical interface (e.g. edge connector, M.2 slot).",
          "items": {
            "$ref": "#/$defs/pcie_interface"
          },
          "minItems": 1
        },
        "video": {
          "type": "object",
          "description": "Video input/output interfaces. Only include keys with non-zero values.",
          "additionalProperties": false,
          "properties": {
            "hdmi_in": { "type": "integer", "minimum": 1 },
            "hdmi_out": { "type": "integer", "minimum": 1 },
            "displayport": { "type": "integer", "minimum": 1 },
            "sdi_in": { "type": "integer", "minimum": 1 },
            "sdi_out": { "type": "integer", "minimum": 1 },
            "aes_in": { "type": "integer", "minimum": 1 },
            "aes_out": { "type": "integer", "minimum": 1 },
            "mipi_dsi": { "type": "integer", "minimum": 1 },
            "mipi_csi": { "type": "integer", "minimum": 1 }
          },
          "minProperties": 1
        },
        "ethernet": {
          "type": "array",
          "description": "Ethernet interfaces grouped by speed. E.g. [{speed: 1000, ports: 2}, {speed: 100, ports: 1}].",
          "items": {
            "$ref": "#/$defs/ethernet_interface"
          },
          "minItems": 1
        },
        "networking": {
          "type": "object",
          "description": "High-speed optical/copper networking interfaces. Only include keys with non-zero values.",
          "additionalProperties": false,
          "properties": {
            "sfp": { "type": "integer", "minimum": 1 },
            "qsfp": { "type": "integer", "minimum": 1 },
            "osfp": { "type": "integer", "minimum": 1 },
            "cfp": { "type": "integer", "minimum": 1 }
          },
          "minProperties": 1
        },
        "expansion": {
          "type": "object",
          "description": "Expansion connectors and headers. Only include keys with non-zero values.",
          "additionalProperties": false,
          "properties": {
            "fmc_hpc": { "type": "integer", "minimum": 1 },
            "fmc_lpc": { "type": "integer", "minimum": 1 },
            "fmcp": { "type": "integer", "minimum": 1 },
            "rfmc": { "type": "integer", "minimum": 1 },
            "pmod": { "type": "integer", "minimum": 1 },
            "arduino": { "type": "integer", "minimum": 1 },
            "raspberry_pi": { "type": "integer", "minimum": 1 },
            "click": { "type": "integer", "minimum": 1 },
            "syzygy": { "type": "integer", "minimum": 1 },
            "syzygy_trx": { "type": "integer", "minimum": 1 }
          },
          "minProperties": 1
        },
        "storage": {
          "type": "object",
          "description": "Storage interfaces. Only include keys with non-zero values.",
          "additionalProperties": false,
          "properties": {
            "sata": { "type": "integer", "minimum": 1 }
          },
          "minProperties": 1
        },
        "wireless": {
          "type": "object",
          "description": "Wireless connectivity.",
          "additionalProperties": false,
          "properties": {
            "wifi": { "type": "boolean" },
            "bluetooth": { "type": "boolean" }
          },
          "minProperties": 1
        }
      }
    },
    "price": {
      "type": "object",
      "required": ["value", "currency"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "description": "Price as a numeric value."
        },
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code (e.g. USD, EUR, GBP)."
        }
      }
    },
    "device": {
      "type": "object",
      "required": ["type", "family", "part", "vendor"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["FPGA", "SoC", "MPSoC", "RFSoC", "ACAP"],
          "description": "Category of the FPGA device."
        },
        "family": {
          "type": "string",
          "description": "Device family name (e.g. Artix-7, Zynq UltraScale+)."
        },
        "part": {
          "type": "string",
          "description": "Orderable manufacturer part number."
        },
        "vendor": {
          "type": "string",
          "description": "Silicon vendor key (must match a key in vendors.json silicon_vendors)."
        }
      }
    },
    "pcie_interface": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Edge", "Slot", "M.2 M-key", "M.2 E-key", "M.2 B-key", "PCIe/104", "iPass"],
          "description": "Physical form factor of the PCIe interface."
        },
        "lanes": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of PCIe lanes."
        },
        "gen": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "description": "PCIe generation (1-6)."
        }
      }
    },
    "ethernet_interface": {
      "type": "object",
      "required": ["speed", "ports"],
      "additionalProperties": false,
      "properties": {
        "speed": {
          "type": "integer",
          "description": "Link speed in Mbps (e.g. 100, 1000, 10000)."
        },
        "ports": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of ports at this speed."
        }
      }
    }
  }
}
