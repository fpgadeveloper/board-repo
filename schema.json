{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FPGA Development Boards",
  "description": "A collection of FPGA development boards with their specifications and features.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/board"
  },
  "$defs": {
    "board": {
      "type": "object",
      "required": ["mpn", "name", "status", "url", "vendor", "price", "device"],
      "additionalProperties": false,
      "properties": {
        "mpn": {
          "type": "string",
          "title": "Part Number",
          "description": "Manufacturer part number (MPN / SKU) as published by the board vendor. Must be unique across all boards. URL-safe characters only (letters, digits, hyphens, dots, underscores). Replace spaces or slashes with hyphens; drop trailing PCB-revision suffixes so the MPN stays stable across revisions."
        },
        "name": {
          "type": "string",
          "title": "Name",
          "description": "Display name of the board."
        },
        "status": {
          "type": "string",
          "title": "Status",
          "enum": ["active", "nrnd", "eol", "discontinued"],
          "description": "Whether the board is currently available, not recommended for new designs, end-of-life, or discontinued."
        },
        "url": {
          "type": "string",
          "title": "Product Page",
          "format": "uri",
          "description": "Product page URL."
        },
        "vendor": {
          "type": "string",
          "title": "Board Vendor",
          "description": "Board vendor key (must match a key in vendors.json board_vendors)."
        },
        "price": {
          "title": "Price",
          "description": "Board price. Use null when the price is unknown or not published by the vendor.",
          "anyOf": [
            { "$ref": "#/$defs/price" },
            { "type": "null" }
          ]
        },
        "device": {
          "title": "Device",
          "$ref": "#/$defs/device"
        },
        "memory": {
          "type": "array",
          "title": "Memory",
          "description": "On-board DRAM. List one entry per distinct memory bank (e.g. soldered DDR4 + a SODIMM slot is two entries).",
          "items": {
            "$ref": "#/$defs/memory_interface"
          },
          "minItems": 1
        },
        "pcie": {
          "type": "array",
          "title": "PCIe",
          "description": "PCIe interfaces on the board. Each entry is a separate physical interface (e.g. edge connector, M.2 slot).",
          "items": {
            "$ref": "#/$defs/pcie_interface"
          },
          "minItems": 1
        },
        "video": {
          "type": "object",
          "title": "Video I/O",
          "description": "Video input/output interfaces. Only include keys with non-zero values.",
          "additionalProperties": false,
          "properties": {
            "hdmi_in": { "type": "integer", "title": "HDMI In", "minimum": 1 },
            "hdmi_out": { "type": "integer", "title": "HDMI Out", "minimum": 1 },
            "displayport": { "type": "integer", "title": "DisplayPort", "minimum": 1 },
            "sdi_in": { "type": "integer", "title": "SDI In", "minimum": 1 },
            "sdi_out": { "type": "integer", "title": "SDI Out", "minimum": 1 },
            "aes_in": { "type": "integer", "title": "AES3 In", "minimum": 1 },
            "aes_out": { "type": "integer", "title": "AES3 Out", "minimum": 1 },
            "mipi_dsi": { "type": "integer", "title": "MIPI DSI", "minimum": 1 },
            "mipi_csi": { "type": "integer", "title": "MIPI CSI", "minimum": 1 },
            "vga_out": { "type": "integer", "title": "VGA Out", "minimum": 1 }
          },
          "minProperties": 1
        },
        "networking": {
          "type": "object",
          "title": "Networking",
          "description": "All networking interfaces — Ethernet ports plus high-speed optical/copper cages. Only include keys with non-zero / non-empty values.",
          "additionalProperties": false,
          "properties": {
            "ethernet": {
              "type": "array",
              "title": "Ethernet",
              "description": "Ethernet interfaces grouped by speed. E.g. [{speed: 1000, ports: 2}, {speed: 100, ports: 1}].",
              "items": {
                "$ref": "#/$defs/ethernet_interface"
              },
              "minItems": 1
            },
            "sfp": { "type": "integer", "title": "SFP/SFP+", "minimum": 1 },
            "qsfp": { "type": "integer", "title": "QSFP/QSFP+", "minimum": 1 },
            "osfp": { "type": "integer", "title": "OSFP", "minimum": 1 },
            "cfp": { "type": "integer", "title": "CFP", "minimum": 1 }
          },
          "minProperties": 1
        },
        "usb": {
          "type": "array",
          "title": "USB",
          "description": "USB interfaces accessible to the FPGA design (fabric or hard IP). Excludes USB-UART/JTAG bridge ports — those go in usb_bridge.",
          "items": {
            "$ref": "#/$defs/usb_interface"
          },
          "minItems": 1
        },
        "usb_bridge": {
          "type": "array",
          "title": "USB UART/JTAG",
          "description": "USB-to-UART/JTAG bridge ports for board configuration and serial console (e.g. FT2232, CP2102, USB-Blaster). Not connected to the FPGA fabric.",
          "items": {
            "$ref": "#/$defs/usb_bridge_interface"
          },
          "minItems": 1
        },
        "expansion": {
          "type": "object",
          "title": "Expansion",
          "description": "Expansion connectors and headers. Only include keys with non-zero values.",
          "additionalProperties": false,
          "properties": {
            "fmc_hpc": { "type": "integer", "title": "FMC HPC", "minimum": 1 },
            "fmc_lpc": { "type": "integer", "title": "FMC LPC", "minimum": 1 },
            "fmcp": { "type": "integer", "title": "FMC+", "minimum": 1 },
            "rfmc": { "type": "integer", "title": "RFMC", "minimum": 1 },
            "pmod": { "type": "integer", "title": "Pmod", "minimum": 1 },
            "arduino": { "type": "integer", "title": "Arduino", "minimum": 1 },
            "raspberry_pi": { "type": "integer", "title": "Raspberry Pi", "minimum": 1 },
            "click": { "type": "integer", "title": "Click", "minimum": 1 },
            "syzygy": { "type": "integer", "title": "SYZYGY", "minimum": 1 },
            "syzygy_trx": { "type": "integer", "title": "SYZYGY TRX", "minimum": 1 }
          },
          "minProperties": 1
        },
        "storage": {
          "type": "object",
          "title": "Storage",
          "description": "Storage interfaces. Only include keys with non-zero values.",
          "additionalProperties": false,
          "properties": {
            "sata": { "type": "integer", "title": "SATA", "minimum": 1 }
          },
          "minProperties": 1
        },
        "wireless": {
          "type": "object",
          "title": "Wireless",
          "description": "Wireless connectivity.",
          "additionalProperties": false,
          "properties": {
            "wifi": { "type": "boolean", "title": "WiFi" },
            "bluetooth": { "type": "boolean", "title": "Bluetooth" }
          },
          "minProperties": 1
        }
      }
    },
    "price": {
      "type": "object",
      "required": ["value", "currency"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "description": "Price as a numeric value."
        },
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code (e.g. USD, EUR, GBP)."
        }
      }
    },
    "device": {
      "type": "object",
      "required": ["part", "vendor"],
      "additionalProperties": false,
      "properties": {
        "part": {
          "type": "string",
          "description": "Orderable manufacturer part number."
        },
        "vendor": {
          "type": "string",
          "description": "Silicon vendor key (must match a key in vendors.json silicon_vendors)."
        }
      }
    },
    "pcie_interface": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Edge", "Slot", "M.2 M-key", "M.2 E-key", "M.2 B-key", "PCIe/104", "iPass"],
          "description": "Physical form factor of the PCIe interface."
        },
        "lanes": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of PCIe lanes."
        },
        "gen": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "description": "PCIe generation (1-6)."
        }
      }
    },
    "ethernet_interface": {
      "type": "object",
      "required": ["speed", "ports"],
      "additionalProperties": false,
      "properties": {
        "speed": {
          "type": "integer",
          "description": "Link speed in Mbps (e.g. 100, 1000, 10000)."
        },
        "ports": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of ports at this speed."
        }
      }
    },
    "usb_connector": {
      "type": "string",
      "enum": ["Type-A", "Type-B", "Type-C", "Mini-B", "Micro-B", "Header"],
      "description": "Physical USB connector on the board."
    },
    "usb_interface": {
      "type": "object",
      "required": ["connector", "speed", "role"],
      "additionalProperties": false,
      "properties": {
        "connector": { "$ref": "#/$defs/usb_connector" },
        "speed": {
          "type": "string",
          "enum": ["1.1", "2.0", "3.0", "3.1", "3.2", "4"],
          "description": "USB version (e.g. 2.0 = High-Speed 480 Mbps, 3.0 = SuperSpeed 5 Gbps)."
        },
        "role": {
          "type": "string",
          "enum": ["host", "device", "otg"],
          "description": "host = peripherals plug in (Type-A), device = board acts as peripheral, otg = either."
        },
        "ports": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of physical ports of this kind. Defaults to 1 if omitted."
        }
      }
    },
    "usb_bridge_interface": {
      "type": "object",
      "required": ["connector", "functions"],
      "additionalProperties": false,
      "properties": {
        "connector": { "$ref": "#/$defs/usb_connector" },
        "functions": {
          "type": "array",
          "items": { "type": "string", "enum": ["jtag", "uart"] },
          "minItems": 1,
          "uniqueItems": true,
          "description": "What the bridge does — typically [\"jtag\", \"uart\"] for combined chips like FT2232."
        },
        "ports": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of physical ports of this kind. Defaults to 1 if omitted."
        }
      }
    },
    "memory_interface": {
      "type": "object",
      "required": ["type", "size_mb"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["DDR2", "DDR3", "DDR3L", "DDR4", "DDR5", "LPDDR2", "LPDDR3", "LPDDR4", "LPDDR4X", "LPDDR5", "HBM2", "HBM2E", "HBM3", "QDR-II+", "QDR-IV"],
          "description": "DRAM family. HBM variants are on-package, not strictly DDR — listed here because they fill the same role in spec sheets."
        },
        "size_mb": {
          "type": "integer",
          "minimum": 1,
          "description": "Total capacity of this bank in megabytes. 4 GB → 4096."
        },
        "form_factor": {
          "type": "string",
          "enum": ["component", "sodimm", "dimm", "udimm", "rdimm", "lrdimm"],
          "description": "Physical form. 'component' = soldered DRAM (default). Slot-based = sodimm / dimm / etc."
        },
        "width_bits": {
          "type": "integer",
          "enum": [16, 32, 64, 72, 128, 256],
          "description": "Data bus width. 72 typically implies ECC."
        },
        "ecc": {
          "type": "boolean",
          "description": "True when this bank has ECC (error-correcting) support."
        }
      }
    }
  }
}
