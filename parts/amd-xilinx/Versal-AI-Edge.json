{
  "family": "Versal AI Edge",
  "description": "Versal AI Edge series with AI Engines optimized for edge inference. Part format: {grade}V{series}{device}-{speed}{voltage}{screen}{pitch}{lid}{rohs}{footprint}-{temp}[-{stepping}]",
  "fields": [
    {
      "id": "product_grade",
      "label": "Product Grade",
      "description": "Product grade prefix indicating target market.",
      "length": 2,
      "type": "select",
      "options": [
        {
          "value": "XC",
          "label": "XC",
          "description": "Commercial"
        },
        {
          "value": "XA",
          "label": "XA",
          "description": "Automotive"
        },
        {
          "value": "XQ",
          "label": "XQ",
          "description": "Defense Grade"
        }
      ]
    },
    {
      "id": "versal",
      "label": "Versal",
      "description": "Versal platform identifier.",
      "length": 1,
      "type": "fixed",
      "value": "V"
    },
    {
      "id": "series",
      "label": "Series",
      "description": "Versal AI Edge series identifier.",
      "length": 1,
      "type": "fixed",
      "value": "E"
    },
    {
      "id": "device_number",
      "label": "Device Number",
      "description": "4-digit device identifier. Digits 1-3: value identifier, digit 4: number of primary cores.",
      "length": null,
      "type": "select",
      "options": [
        {
          "value": "1752",
          "label": "1752",
          "description": "Value ID 175, 2 primary core(s)"
        },
        {
          "value": "2002",
          "label": "2002",
          "description": "Value ID 200, 2 primary core(s)"
        },
        {
          "value": "2102",
          "label": "2102",
          "description": "Value ID 210, 2 primary core(s)"
        },
        {
          "value": "2202",
          "label": "2202",
          "description": "Value ID 220, 2 primary core(s)"
        },
        {
          "value": "2302",
          "label": "2302",
          "description": "Value ID 230, 2 primary core(s)"
        },
        {
          "value": "2602",
          "label": "2602",
          "description": "Value ID 260, 2 primary core(s)"
        },
        {
          "value": "2802",
          "label": "2802",
          "description": "Value ID 280, 2 primary core(s)"
        }
      ]
    },
    {
      "id": "sep1",
      "label": "Separator",
      "description": "Dash separator.",
      "length": 1,
      "type": "fixed",
      "value": "-"
    },
    {
      "id": "speed_grade",
      "label": "Speed Grade",
      "description": "Device speed grade. 1 = slowest, 3 = highest performance.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "1",
          "label": "Speed grade 1",
          "description": "Slowest"
        },
        {
          "value": "2",
          "label": "Speed grade 2",
          "description": "Mid",
          "when": {
            "product_grade": [
              "XC",
              "XQ"
            ]
          }
        },
        {
          "value": "3",
          "label": "Speed grade 3",
          "description": "Highest",
          "when": {
            "product_grade": [
              "XC"
            ]
          }
        }
      ]
    },
    {
      "id": "voltage",
      "label": "Voltage",
      "description": "Core voltage level.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "H",
          "label": "High voltage",
          "description": "High voltage",
          "when": {
            "product_grade": [
              "XC"
            ]
          }
        },
        {
          "value": "L",
          "label": "Low voltage",
          "description": "Low voltage"
        },
        {
          "value": "M",
          "label": "Mid voltage",
          "description": "Mid voltage",
          "when": {
            "product_grade": [
              "XC",
              "XQ"
            ]
          }
        }
      ]
    },
    {
      "id": "static_screen",
