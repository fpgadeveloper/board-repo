        },
        {
          "value": "I",
          "label": "I",
          "description": "-40\u00b0C to 110\u00b0C"
        },
        {
          "value": "M",
          "label": "M",
          "description": "-55\u00b0C to 125\u00b0C",
          "when": {
            "product_grade": [
              "XQ"
            ]
          }
        },
        {
          "value": "Q",
          "label": "Q",
          "description": "-40\u00b0C to 125\u00b0C",
          "when": {
            "product_grade": [
              "XA"
            ]
          }
        }
      ]
    },
    {
      "id": "ball_pitch",
      "label": "Ball Pitch",
