{
  "family": "Versal Prime",
  "description": "Versal Prime series, general-purpose adaptive compute platform. Part format: {grade}V{series}{device}-{speed}{voltage}{screen}{pitch}{lid}{rohs}{footprint}-{temp}[-{stepping}]",
  "fields": [
    {
      "id": "product_grade",
      "label": "Product Grade",
      "description": "Product grade prefix indicating target market.",
      "length": 2,
      "type": "select",
      "options": [
        {
          "value": "XC",
          "label": "XC",
          "description": "Commercial"
        },
        {
          "value": "XA",
          "label": "XA",
          "description": "Automotive"
        },
        {
          "value": "XQ",
          "label": "XQ",
          "description": "Defense Grade"
        }
      ]
    },
    {
      "id": "versal",
      "label": "Versal",
      "description": "Versal platform identifier.",
      "length": 1,
      "type": "fixed",
      "value": "V"
    },
    {
      "id": "series",
      "label": "Series",
      "description": "Versal Prime series identifier.",
      "length": 1,
      "type": "fixed",
      "value": "M"
    },
    {
      "id": "device_number",
      "label": "Device Number",
      "description": "4-digit device identifier. Digits 1-3: value identifier, digit 4: number of primary cores.",
