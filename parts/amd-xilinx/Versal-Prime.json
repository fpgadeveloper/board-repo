        },
        {
          "value": "1802",
          "label": "1802",
          "description": "Value ID 180, 2 primary core(s)"
        },
        {
          "value": "2152",
          "label": "2152",
          "description": "Value ID 215, 2 primary core(s)"
        },
        {
          "value": "2202",
          "label": "2202",
          "description": "Value ID 220, 2 primary core(s)"
        },
        {
          "value": "2302",
          "label": "2302",
