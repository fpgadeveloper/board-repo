      "options": [
        {
          "value": "1102",
          "label": "1102",
          "description": "Value ID 110, 2 primary core(s)"
        },
        {
          "value": "1302",
          "label": "1302",
          "description": "Value ID 130, 2 primary core(s)"
        },
        {
          "value": "1402",
          "label": "1402",
