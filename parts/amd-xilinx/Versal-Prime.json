      "label": "Separator",
      "description": "Dash separator.",
      "length": 1,
      "type": "fixed",
      "value": "-"
    },
    {
      "id": "speed_grade",
      "label": "Speed Grade",
      "description": "Device speed grade. 1 = slowest, 3 = highest performance.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "1",
          "label": "Speed grade 1",
          "description": "Slowest"
        },
        {
          "value": "2",
          "label": "Speed grade 2",
          "description": "Mid",
          "when": {
            "product_grade": [
              "XC",
              "XQ"
            ]
          }
        },
        {
          "value": "3",
          "label": "Speed grade 3",
          "description": "Highest",
          "when": {
            "product_grade": [
              "XC"
            ]
          }
        }
      ]
    },
    {
      "id": "voltage",
      "label": "Voltage",
      "description": "Core voltage level.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "H",
          "label": "High voltage",
          "description": "High voltage",
          "when": {
            "product_grade": [
              "XC"
            ]
          }
        },
        {
          "value": "L",
          "label": "Low voltage",
          "description": "Low voltage"
        },
        {
          "value": "M",
          "label": "Mid voltage",
          "description": "Mid voltage",
          "when": {
            "product_grade": [
              "XC",
              "XQ"
            ]
          }
        }
      ]
    },
    {
      "id": "static_screen",
