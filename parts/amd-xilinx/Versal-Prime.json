          "value": "N",
          "label": "0.94mm no LSC",
          "description": "0.94mm no LSC"
        },
        {
          "value": "S",
          "label": "0.8mm",
          "description": "0.8mm"
        },
        {
          "value": "V",
          "label": "0.94mm w/ LSC",
          "description": "0.94mm w/ LSC"
        }
      ]
    },
    {
      "id": "lid",
      "label": "Lid",
      "description": "Package lid configuration.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "B",
          "label": "Lidless, no stiffener ring",
          "description": "Lidless, no stiffener ring"
        },
        {
          "value": "F",
          "label": "Lidded",
          "description": "Lidded"
        },
        {
          "value": "S",
          "label": "Lidless w/ stiffener ring",
          "description": "Lidless w/ stiffener ring"
        }
      ]
    },
    {
      "id": "rohs",
      "label": "RoHS6 Code",
      "description": "RoHS compliance and ball material.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "R",
