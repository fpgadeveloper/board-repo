{
  "family": "Certus-NX",
  "description": "Lattice Certus-NX general-purpose low-power FPGA built on the Nexus platform (28 nm FD-SOI). Format: LFD2NX-{density}-{speed}{package}{temp}.",
  "fields": [
    {
      "id": "prefix",
      "label": "Prefix",
      "description": "Fixed prefix identifying the Certus-NX family.",
      "length": 6,
      "type": "fixed",
      "value": "LFD2NX"
    },
    {
      "id": "sep1",
      "label": "Separator",
      "description": "Dash separator after prefix.",
      "length": 1,
      "type": "fixed",
      "value": "-"
    },
    {
      "id": "density",
      "label": "Logic Capacity",
      "description": "Device logic density.",
      "length": 2,
      "type": "select",
      "options": [
        {
          "value": "17",
          "label": "17",
          "description": "17k logic cells."
        },
        {
          "value": "40",
          "label": "40",
          "description": "39k logic cells."
        }
      ]
    },
    {
      "id": "sep2",
      "label": "Separator",
      "description": "Dash separator before speed grade.",
      "length": 1,
      "type": "fixed",
      "value": "-"
    },
    {
      "id": "speed",
      "label": "Speed Grade",
      "description": "Fabric speed grade. 9 is fastest. Same number applies to HP and LP variants.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "7",
          "label": "Speed 7",
          "description": "Slowest speed grade."
        },
        {
          "value": "8",
          "label": "Speed 8",
          "description": "Mid-range speed grade."
        },
        {
          "value": "9",
          "label": "Speed 9",
          "description": "Fastest speed grade."
        }
      ]
    },
    {
      "id": "package",
      "label": "Package",
      "description": "Package type and ball count.",
      "length": null,
      "type": "select",
      "options": [
        {
          "value": "MG121",
          "label": "MG121",
          "description": "121-ball csfBGA."
        },
        {
          "value": "BG196",
          "label": "BG196",
          "description": "196-ball caBGA."
        },
        {
          "value": "BG256",
          "label": "BG256",
          "description": "256-ball caBGA."
        }
      ]
    },
    {
      "id": "temp",
      "label": "Temperature Grade",
      "description": "Operating temperature range.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "C",
          "label": "Commercial",
          "description": "0 C to +85 C."
        },
        {
          "value": "I",
          "label": "Industrial",
          "description": "-40 C to +100 C."
        },
        {
          "value": "A",
          "label": "Automotive",
          "description": "Automotive grade (speed 7 only)."
        }
      ]
    }
  ],
  "type": "FPGA"
}
