{
  "family": "iCE40",
  "description": "Lattice iCE40 ultra-low-power FPGA family. Covers LP (Low Power), HX (High Performance), UL (UltraLite), and UP (UltraPlus) sub-families. Format: ICE40{sub_family}{density}-{package}[I][{shipping}]. The 'I' (Industrial) grade letter is present for UL and UP parts only; LP/HX parts ship industrial without a temperature letter.",
  "fields": [
    {
      "id": "prefix",
      "label": "Prefix",
      "description": "Fixed prefix identifying the iCE40 family.",
      "length": 5,
      "type": "fixed",
      "value": "ICE40"
    },
    {
      "id": "sub_family",
      "label": "Sub-family",
      "description": "Identifies the iCE40 sub-family, which determines the available densities, packages, and part-number suffix format.",
      "length": null,
      "type": "select",
      "options": [
        {
          "value": "LP",
          "label": "LP (Low Power)",
          "description": "Low Power — optimised for lowest static power consumption."
        },
        {
          "value": "HX",
          "label": "HX (High Performance)",
          "description": "High Performance — higher clock speeds and more I/O."
        },
        {
          "value": "UL",
          "label": "UL (UltraLite)",
          "description": "UltraLite — smallest packages, ultra-low power, mobile-oriented."
        },
        {
          "value": "UP",
          "label": "UP (UltraPlus)",
          "description": "UltraPlus — adds DSP blocks, extra SRAM, and I2C/SPI hard IP."
        }
      ]
    },
    {
      "id": "density",
      "label": "Density",
      "description": "Device logic density.",
      "length": null,
      "type": "select",
      "options": [
        {
          "value": "384",
          "label": "384",
          "description": "384 logic cells.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "640",
          "label": "640",
          "description": "640 logic cells.",
          "when": { "sub_family": ["LP", "UL"] }
        },
        {
          "value": "1K",
          "label": "1K",
          "description": "1,280 logic cells (1,248 in UL).",
          "when": { "sub_family": ["LP", "HX", "UL"] }
        },
        {
          "value": "3K",
          "label": "3K",
          "description": "2,800 logic cells.",
          "when": { "sub_family": ["UP"] }
        },
        {
          "value": "4K",
          "label": "4K",
          "description": "3,520 logic cells.",
          "when": { "sub_family": ["LP", "HX"] }
        },
        {
          "value": "5K",
          "label": "5K",
          "description": "5,280 logic cells.",
          "when": { "sub_family": ["UP"] }
        },
        {
          "value": "8K",
          "label": "8K",
          "description": "7,680 logic cells.",
          "when": { "sub_family": ["LP", "HX"] }
        }
      ]
    },
    {
      "id": "sep1",
      "label": "Separator",
      "description": "Dash separator between density and package.",
      "length": 1,
      "type": "fixed",
      "value": "-"
    },
    {
      "id": "package",
      "label": "Package",
      "description": "Package type and pin/ball count.",
      "length": null,
      "type": "select",
      "options": [
        {
          "value": "SWG16",
          "label": "SWG16",
          "description": "16-Ball WLCSP, 0.35 mm ball pitch.",
          "when": { "sub_family": ["LP", "UL"] }
        },
        {
          "value": "SG32",
          "label": "SG32",
          "description": "32-Pin QFN, 0.50 mm pin pitch.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "SG48",
          "label": "SG48",
          "description": "48-Pin QFN, 0.50 mm pin pitch.",
          "when": { "sub_family": ["UP"] }
        },
        {
          "value": "QN84",
          "label": "QN84",
          "description": "84-Pin QFN, 0.50 mm pin pitch.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "CM36",
          "label": "CM36",
          "description": "36-Ball ucBGA, 0.40 mm ball pitch.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "CM36A",
          "label": "CM36A",
          "description": "36-Ball ucBGA, 0.40 mm ball pitch (Type A, alternative pinout).",
          "when": { "sub_family": ["LP", "UL"] }
        },
        {
          "value": "CM49",
          "label": "CM49",
          "description": "49-Ball ucBGA, 0.40 mm ball pitch.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "CM81",
          "label": "CM81",
          "description": "81-Ball ucBGA, 0.40 mm ball pitch.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "CM121",
          "label": "CM121",
          "description": "121-Ball ucBGA, 0.40 mm ball pitch.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "CM225",
          "label": "CM225",
          "description": "225-Ball ucBGA, 0.40 mm ball pitch.",
          "when": { "sub_family": ["LP", "HX"] }
        },
        {
          "value": "CB81",
          "label": "CB81",
          "description": "81-Ball csBGA, 0.50 mm ball pitch.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "CB121",
          "label": "CB121",
          "description": "121-Ball csBGA, 0.50 mm ball pitch.",
          "when": { "sub_family": ["LP"] }
        },
        {
          "value": "CB132",
          "label": "CB132",
          "description": "132-Ball csBGA, 0.50 mm ball pitch.",
          "when": { "sub_family": ["HX"] }
        },
        {
          "value": "BG121",
          "label": "BG121",
          "description": "121-Ball caBGA, 0.80 mm ball pitch.",
          "when": { "sub_family": ["HX"] }
        },
        {
          "value": "CT256",
          "label": "CT256",
          "description": "256-Ball caBGA, 0.80 mm ball pitch.",
          "when": { "sub_family": ["HX"] }
        },
        {
          "value": "TQ144",
          "label": "TQ144",
          "description": "144-Pin TQFP, 0.50 mm pin pitch.",
          "when": { "sub_family": ["HX"] }
        },
        {
          "value": "VQ100",
          "label": "VQ100",
          "description": "100-Pin VQFP, 0.50 mm pin pitch.",
          "when": { "sub_family": ["HX"] }
        },
        {
          "value": "UWG30",
          "label": "UWG30",
          "description": "30-Ball WLCSP, 0.40 mm ball pitch.",
          "when": { "sub_family": ["UP"] }
        }
      ]
    },
    {
      "id": "temp",
      "label": "Temperature Grade",
      "description": "Operating temperature range. Present only for UltraLite and UltraPlus parts; LP and HX parts ship industrial without a letter.",
      "length": 1,
      "type": "select",
      "required": false,
      "options": [
        {
          "value": "I",
          "label": "Industrial",
          "description": "-40 °C to +85 °C.",
          "when": { "sub_family": ["UL", "UP"] }
        }
      ]
    },
    {
      "id": "shipping",
      "label": "Shipping Method",
      "description": "Optional packaging/shipping suffix. Omitted means trays (UL) or default tape and reel (UP SG48).",
      "length": null,
      "type": "select",
      "required": false,
      "options": [
        {
          "value": "TR1K",
          "label": "TR1K",
          "description": "Tape and Reel, 1,000 units."
        },
        {
          "value": "TR50",
          "label": "TR50",
          "description": "Tape and Reel, 50 units.",
          "when": { "sub_family": ["UP"] }
        },
        {
          "value": "TR",
          "label": "TR",
          "description": "Tape and Reel (default quantity per package)."
        }
      ]
    }
  ],
  "type": "FPGA"
}
