      "options": [
        {
          "value": "B17",
          "label": "B17",
          "description": "Base EOS S3 variant \u2014 Cortex-M4F + eFPGA."
        }
      ]
    },
    {
      "id": "sep2",
      "label": "Separator",
      "description": "Dash separator.",
