{
  "family": "GW1N (LittleBee)",
  "description": "Gowin LittleBee GW1N family \u2014 low-power, small-footprint FPGAs. Format: GW1N{sub}-{voltage}{density}{qualifier}{package}{speed}. Sub-variants include R (embedded SDRAM), S (embedded ARM), Z (low-power), and RF (BLE radio).",
  "fields": [
    {
      "id": "prefix",
      "label": "Prefix",
      "description": "Gowin vendor prefix.",
      "length": 2,
      "type": "fixed",
      "value": "GW"
    },
    {
      "id": "family",
      "label": "Family",
      "description": "LittleBee family identifier.",
      "length": 2,
      "type": "fixed",
      "value": "1N"
    },
    {
      "id": "sub_variant",
      "label": "Sub-Variant",
      "description": "Optional sub-variant indicating integrated hard IP or feature set.",
      "length": null,
      "type": "select",
      "required": false,
      "options": [
        {
          "value": "R",
          "label": "R (SDRAM)",
          "description": "Embedded SDRAM (e.g. 64 Mbit PSRAM)."
        },
        {
          "value": "S",
          "label": "S (ARM)",
          "description": "Embedded ARM Cortex-M3 hard processor."
        },
        {
          "value": "Z",
          "label": "Z (Low-Power)",
          "description": "Ultra-low-power variant."
        },
        {
          "value": "RF",
          "label": "RF (BLE)",
          "description": "Embedded Bluetooth Low Energy radio."
        }
      ]
    },
    {
      "id": "sep1",
      "label": "Separator",
      "description": "Dash separator.",
      "length": 1,
      "type": "fixed",
      "value": "-"
    },
    {
      "id": "voltage",
      "label": "Core Voltage",
      "description": "Core voltage variant. Blank for standard 1.2V core.",
      "length": null,
      "type": "select",
      "required": false,
      "options": [
        {
          "value": "LV",
          "label": "LV (Low Voltage)",
          "description": "1.0V core voltage."
        },
        {
          "value": "UV",
          "label": "UV (Ultra-Low Voltage)",
          "description": "0.9V core voltage."
        }
      ]
    },
    {
      "id": "density",
      "label": "Density",
      "description": "Logic density designation (approximate LUT4 count in thousands).",
      "length": null,
      "type": "select",
      "options": [
        {
          "value": "1",
          "label": "1K",
          "description": "~1,152 LUT4s."
        },
        {
          "value": "2",
          "label": "2K",
          "description": "~2,304 LUT4s."
        },
        {
          "value": "4",
          "label": "4K",
          "description": "~4,608 LUT4s."
        },
        {
          "value": "9",
          "label": "9K",
          "description": "~8,640 LUT4s."
