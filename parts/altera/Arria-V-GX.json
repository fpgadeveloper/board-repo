{
  "family": "Arria V GX",
  "description": "Altera Arria V GX FPGA with 6-Gbps transceivers. Format: 5AGX{hard_ip}{member}{xcvr_count}{xcvr_speed}F{pkg_code}{temp}{fabric_speed}[N]. Example: 5AGXMA5G4F35C4N.",
  "fields": [
    {"id": "prefix", "label": "Prefix", "description": "Arria V family signature.", "length": 2, "type": "fixed", "value": "5A"},
