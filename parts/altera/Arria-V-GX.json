    {"id": "suffix", "label": "Optional Suffix", "description": "Lead-free or sample suffix.", "length": null, "type": "select", "required": false, "options": [
      {"value": "N", "label": "N", "description": "Lead-free packaging."},
      {"value": "ES", "label": "ES", "description": "Engineering sample."}
    ]}
