      {"value": "B", "label": "B", "description": "B-series member."}
    ]},
    {"id": "member", "label": "Member Density", "description": "Member density digit.", "length": 1, "type": "select", "options": [
      {"value": "1", "label": "1", "description": "A1=75K LE / B1=300K LE."},
      {"value": "3", "label": "3", "description": "A3=149K LE / B3=362K LE."},
      {"value": "5", "label": "5", "description": "A5=190K LE / B5=420K LE."},
      {"value": "7", "label": "7", "description": "A7=243K LE / B7=503K LE."}
    ]},
    {"id": "xcvr_count", "label": "Transceiver Count", "description": "Number of transceiver channels.", "length": 1, "type": "select", "options": [
      {"value": "D", "label": "D (9)", "description": "9 transceivers."},
      {"value": "E", "label": "E (12)", "description": "12 transceivers."},
      {"value": "G", "label": "G (18)", "description": "18 transceivers."},
      {"value": "H", "label": "H (24)", "description": "24 transceivers."},
      {"value": "K", "label": "K (36)", "description": "36 transceivers."}
    ]},
    {"id": "xcvr_speed", "label": "Transceiver Speed Grade", "description": "Max transceiver data rate.", "length": 1, "type": "select", "options": [
      {"value": "4", "label": "4 (6 Gbps)", "description": "6 Gbps transceiver speed grade."},
      {"value": "5", "label": "5", "description": "Speed grade 5."},
      {"value": "6", "label": "6 (3 Gbps)", "description": "3 Gbps transceiver speed grade."}
    ]},
    {"id": "package_type", "label": "Package Type", "description": "Package family.", "length": 1, "type": "fixed", "value": "F"},
    {"id": "package_code", "label": "Package Code", "description": "Package pin-count code.", "length": 2, "type": "select", "options": [
      {"value": "27", "label": "27 (FBGA 672)", "description": "FBGA, 672 pins."},
      {"value": "31", "label": "31 (FBGA 896)", "description": "FBGA, 896 pins."},
      {"value": "35", "label": "35 (FBGA 1152)", "description": "FBGA, 1,152 pins."},
      {"value": "40", "label": "40 (FBGA 1517)", "description": "FBGA, 1,517 pins."}
    ]},
    {"id": "temp", "label": "Operating Temperature", "description": "Junction temperature range.", "length": 1, "type": "select", "options": [
      {"value": "C", "label": "Commercial", "description": "TJ = 0 to 85 C."},
      {"value": "I", "label": "Industrial", "description": "TJ = -40 to 100 C."}
    ]},
    {"id": "fabric_speed", "label": "FPGA Fabric Speed Grade", "description": "Core fabric speed. 4 = fastest.", "length": 1, "type": "select", "options": [
      {"value": "4", "label": "4", "description": "Fastest fabric speed."},
      {"value": "5", "label": "5", "description": "Speed grade 5."},
      {"value": "6", "label": "6", "description": "Slowest fabric speed."}
