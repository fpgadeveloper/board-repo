      {"value": "M", "label": "M", "description": "1 hard PCIe and 2 hard memory controllers."},
      {"value": "F", "label": "F", "description": "Maximum 2 hard PCIe and 4 hard memory controllers."}
    ]},
    {"id": "member_letter", "label": "Member Family Letter", "description": "Member family letter (A for smaller members, B for larger).", "length": 1, "type": "select", "options": [
