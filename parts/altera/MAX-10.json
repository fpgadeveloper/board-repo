{
  "family": "MAX 10",
  "description": "Altera MAX 10 FPGA part number model. Format: 10M{density}{feature}{package}{pin_count}{speed}{trailing}. Example: 10M50DAF484C8GES.",
  "fields": [
    {
      "id": "prefix",
      "label": "Prefix",
      "description": "Fixed prefix identifying the MAX 10 family.",
      "length": 3,
      "type": "fixed",
      "value": "10M"
    },
    {
      "id": "density",
      "label": "Density",
      "description": "Two-digit code representing the device logic density in K logic elements.",
      "length": 2,
      "type": "select",
      "options": [
        {
          "value": "02",
          "label": "2K LE",
          "description": "~2K logic elements."
        },
        {
          "value": "04",
          "label": "4K LE",
          "description": "~4K logic elements."
        },
        {
          "value": "08",
          "label": "8K LE",
          "description": "~8K logic elements."
        },
        {
          "value": "16",
          "label": "16K LE",
          "description": "~16K logic elements."
        },
        {
          "value": "25",
          "label": "25K LE",
          "description": "~25K logic elements."
        },
        {
          "value": "40",
          "label": "40K LE",
          "description": "~40K logic elements."
        },
        {
          "value": "50",
          "label": "50K LE",
          "description": "~50K logic elements."
        }
      ]
    },
    {
      "id": "feature",
      "label": "Feature",
      "description": "Two-character feature code indicating flash configuration and analog capability.",
      "length": 2,
      "type": "select",
      "options": [
        {
          "value": "DA",
          "label": "Dual Analog",
          "description": "Dual configuration flash with analog (ADC) support."
        },
        {
          "value": "DF",
          "label": "Dual Flash",
          "description": "Dual configuration flash without analog (ADC)."
        },
        {
          "value": "DC",
          "label": "Dual Compact",
          "description": "Dual configuration flash, compact device."
        },
        {
          "value": "SA",
          "label": "Single Analog",
          "description": "Single configuration flash with analog (ADC) support."
        },
        {
          "value": "SC",
          "label": "Single Compact",
          "description": "Single configuration flash, compact device."
        }
      ]
    },
    {
      "id": "package",
      "label": "Package",
      "description": "Single-character package type code.",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "F",
          "label": "FBGA",
          "description": "Fine-pitch BGA package."
        },
        {
          "value": "U",
          "label": "UBGA",
          "description": "Ultra-fine-pitch BGA package."
        },
        {
          "value": "E",
          "label": "EQFP",
          "description": "Enhanced Quad Flat Pack package."
        }
      ]
    },
    {
      "id": "pin_count",
      "label": "Pin Count",
      "description": "Number of package pins.",
      "length": 3,
      "type": "select",
      "options": [
        {
          "value": "144",
          "label": "144 pins",
          "description": "144-pin package."
        },
        {
          "value": "256",
          "label": "256 pins",
          "description": "256-pin package."
        },
        {
          "value": "324",
          "label": "324 pins",
          "description": "324-pin package."
        },
        {
          "value": "484",
          "label": "484 pins",
          "description": "484-pin package."
        },
        {
          "value": "672",
          "label": "672 pins",
          "description": "672-pin package."
        }
      ]
    },
    {
      "id": "speed_grade",
      "label": "Speed Grade",
      "description": "Temperature grade letter and speed grade number.",
      "length": 2,
      "type": "select",
      "options": [
        {
          "value": "C7",
          "label": "Commercial, Speed 7",
          "description": "Commercial temperature, standard speed grade."
        },
        {
          "value": "C8",
          "label": "Commercial, Speed 8",
          "description": "Commercial temperature, economy speed grade."
        },
        {
          "value": "A7",
          "label": "Automotive, Speed 7",
          "description": "Automotive temperature range."
        },
        {
          "value": "I6",
          "label": "Industrial, Speed 6",
          "description": "Industrial temperature, fast speed grade."
        },
        {
          "value": "I7",
          "label": "Industrial, Speed 7",
          "description": "Industrial temperature range."
        }
      ]
    },
    {
      "id": "trailing",
      "label": "Trailing",
      "description": "Optional trailing suffix. G indicates lead-free, ES indicates engineering sample.",
      "length": null,
      "type": "select",
      "required": false,
      "options": [
        {
          "value": "",
          "label": "None",
          "description": "No trailing suffix."
        },
        {
          "value": "G",
          "label": "Pb-free",
          "description": "Lead-free (RoHS-compliant) package."
        },
        {
          "value": "GES",
          "label": "Pb-free Engineering Sample",
          "description": "Lead-free, engineering sample device."
        },
        {
          "value": "ES",
          "label": "Engineering Sample",
          "description": "Pre-production engineering sample device."
        }
      ]
    }
  ],
  "type": "FPGA"
}
