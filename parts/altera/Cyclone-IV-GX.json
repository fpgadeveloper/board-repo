{
  "family": "Cyclone IV GX",
  "description": "Altera Cyclone IV GX FPGA with 3.125-Gbps transceivers. Format: EP4CGX{density}{xcvr_count}{package_type}{package_size}{temp}{speed}[suffix]. Example: EP4CGX30CF19C7N.",
  "fields": [
    {
      "id": "prefix",
      "label": "Family Signature",
      "description": "Cyclone IV GX family signature.",
      "length": 6,
      "type": "fixed",
      "value": "EP4CGX"
    },
    {
      "id": "density",
      "label": "Device Density",
      "description": "Logic density (approximate LE count in thousands).",
      "length": null,
      "type": "select",
      "options": [
        {"value": "15", "label": "EP4CGX15", "description": "15K logic elements."},
        {"value": "22", "label": "EP4CGX22", "description": "22K logic elements."},
        {"value": "30", "label": "EP4CGX30", "description": "30K logic elements."},
        {"value": "50", "label": "EP4CGX50", "description": "50K logic elements."},
        {"value": "75", "label": "EP4CGX75", "description": "75K logic elements."},
        {"value": "110", "label": "EP4CGX110", "description": "110K logic elements."},
        {"value": "150", "label": "EP4CGX150", "description": "150K logic elements."}
      ]
    },
    {
      "id": "xcvr_count",
      "label": "Transceiver Count",
      "description": "Number of 3.125 Gbps transceiver channels.",
      "length": 1,
      "type": "select",
      "options": [
        {"value": "B", "label": "B (2)", "description": "2 transceivers."},
        {"value": "C", "label": "C (4)", "description": "4 transceivers."},
        {"value": "D", "label": "D (8)", "description": "8 transceivers."}
      ]
    },
    {
      "id": "package_type",
      "label": "Package Type",
      "description": "Package family.",
      "length": 1,
      "type": "select",
      "options": [
        {"value": "N", "label": "QFN", "description": "Quad Flat Pack No Lead."},
        {"value": "F", "label": "FBGA", "description": "FineLine BGA."}
      ]
    },
    {
      "id": "package_size",
      "label": "Package Size",
      "description": "Two-digit package pin-count code.",
      "length": 2,
      "type": "select",
      "options": [
        {"value": "11", "label": "11 (QFN 148)", "description": "QFN, 148 pins."},
        {"value": "14", "label": "14 (FBGA 169)", "description": "FBGA, 169 pins."},
        {"value": "19", "label": "19 (FBGA 324)", "description": "FBGA, 324 pins."},
        {"value": "23", "label": "23 (FBGA 484)", "description": "FBGA, 484 pins."},
        {"value": "27", "label": "27 (FBGA 672)", "description": "FBGA, 672 pins."},
        {"value": "31", "label": "31 (FBGA 896)", "description": "FBGA, 896 pins."}
      ]
    },
    {
      "id": "temp",
      "label": "Operating Temperature",
      "description": "Junction temperature range.",
      "length": 1,
      "type": "select",
      "options": [
        {"value": "C", "label": "Commercial", "description": "TJ = 0 to 85 C."},
        {"value": "I", "label": "Industrial", "description": "TJ = -40 to 100 C."}
      ]
    },
    {
      "id": "speed",
      "label": "Speed Grade",
      "description": "Fabric speed grade. 6 = fastest.",
      "length": 1,
      "type": "select",
      "options": [
        {"value": "6", "label": "6", "description": "Fastest speed grade."},
        {"value": "7", "label": "7", "description": "Speed grade 7."},
        {"value": "8", "label": "8", "description": "Slowest speed grade."}
      ]
    },
    {
      "id": "suffix",
      "label": "Optional Suffix",
      "description": "Optional shipment-method suffix.",
      "length": null,
      "type": "select",
      "required": false,
      "options": [
        {"value": "N", "label": "N", "description": "Lead-free packaging."},
        {"value": "ES", "label": "ES", "description": "Engineering sample."}
      ]
    }
