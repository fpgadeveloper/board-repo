{
  "family": "GateMate",
  "description": "Cologne Chip GateMate Series \u2014 European-designed FPGAs based on Cologne Chip's proprietary Programmable Element (CPE) architecture. Format: CCGM1A{density}-{package}[{grade}]{suffix}. Example: CCGM1A1-BGA324.",
  "fields": [
    {
      "id": "prefix",
      "label": "Prefix",
      "description": "Cologne Chip GateMate 1st generation, A-series prefix.",
      "length": 6,
      "type": "fixed",
      "value": "CCGM1A"
    },
    {
      "id": "density",
      "label": "Density",
      "description": "Logic density designation (A1 = 20,480 CPEs, A2 = 40,960 CPEs).",
      "length": 1,
      "type": "select",
      "options": [
        {
          "value": "1",
          "label": "A1",
          "description": "CCGM1A1 \u2014 20,480 Configurable Processing Elements (CPEs)."
        },
        {
          "value": "2",
          "label": "A2",
          "description": "CCGM1A2 \u2014 40,960 Configurable Processing Elements (CPEs)."
        }
      ]
    },
    {
      "id": "sep1",
      "label": "Separator",
      "description": "Dash separator before package code.",
      "length": 1,
      "type": "fixed",
      "value": "-"
    },
    {
      "id": "package",
      "label": "Package",
      "description": "Package type and pin count.",
      "length": null,
      "type": "select",
      "options": [
        {
          "value": "QFN48",
          "label": "QFN48",
          "description": "48-pin QFN package."
        },
        {
          "value": "QFN100",
          "label": "QFN100",
          "description": "100-pin QFN package."
        },
        {
          "value": "BGA256",
          "label": "BGA256",
          "description": "256-ball BGA package."
        },
        {
          "value": "BGA324",
          "label": "BGA324",
          "description": "324-ball BGA package."
        },
        {
          "value": "BGA484",
          "label": "BGA484",
          "description": "484-ball BGA package."
        }
      ]
    },
    {
      "id": "grade",
      "label": "Grade",
      "description": "Optional temperature / qualification grade.",
      "length": 2,
      "type": "select",
      "required": false,
      "options": [
        {
          "value": "C0",
          "label": "C0 (Commercial)",
          "description": "Commercial temperature range (0\u00b0C to 85\u00b0C)."
        },
        {
          "value": "I0",
          "label": "I0 (Industrial)",
          "description": "Industrial temperature range (-40\u00b0C to 100\u00b0C)."
        },
        {
          "value": "A0",
          "label": "A0 (Automotive)",
          "description": "Automotive temperature range (-40\u00b0C to 125\u00b0C)."
        }
      ]
    },
    {
      "id": "suffix",
      "label": "Suffix",
      "description": "Optional suffix for engineering samples.",
      "length": null,
      "type": "select",
      "required": false,
      "options": [
        {
          "value": "ES",
          "label": "ES (Engineering Sample)",
          "description": "Pre-production engineering sample device."
        }
      ]
    }
  ],
  "type": "FPGA"
}
